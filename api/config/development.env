# DTE / SAT Digifact
DTE_AUTH_URL=https://felgttestaws.digifact.com.gt/gt.com.fel.api.v3/api/login/get_token
DTE_CERT_URL_BASE=https://felgttestaws.digifact.com.gt/gt.com.fel.api.v3/api/FELRequestV2?NIT={NIT}&TIPO=CERTIFICATE_DTE_XML_TOSIGN&FORMAT=XML,PDF,HTML&USERNAME={USERNAME}
DTE_CANCEL_URL_BASE=https://felgttestaws.digifact.com.gt/gt.com.fel.api.v3/api/FELRequestV2?NIT={NIT}&TIPO=ANULAR_FEL_TOSIGN&FORMAT=XML,PDF,HTML&USERNAME={USERNAME}